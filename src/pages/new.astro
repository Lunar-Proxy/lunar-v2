---
import '@/main.css';
import Shortcuts from '../layouts/shortcuts.astro';
import quotes from '../../public/a/json/quotes.json';

const randomIndex = Math.floor(Math.random() * quotes.length);
const randomQuote = quotes[randomIndex]?.quote || '';
---

<!doctype html>
<html lang="en" style="background:#232136;">
  <head>
    <meta charset="UTF-8" />
    <title>New Tab</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <style>
      html,
      body {
        background: #232136;
        color: #e0def4;
      }
    </style>
  </head>

  <body
    class="font-linux bg-background text-text-header relative flex h-screen w-screen flex-col items-center justify-center overflow-hidden"
  >
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div
        class="absolute -top-24 left-1/2 h-125 w-175 rounded-full opacity-[0.08]"
        style="background: radial-gradient(ellipse, rgba(var(--accent-rgb), 0.28) 0%, transparent 72%);"
      >
      </div>
      <div
        class="absolute right-[10%] -bottom-20 h-100 w-125 opacity-[0.06]"
        style="background: radial-gradient(ellipse, rgba(var(--accent-rgb), 0.2) 0%, transparent 72%);"
      >
      </div>
    </div>

    <div class="relative z-10 flex flex-col items-center space-y-7">
      <div id="clock" class="flex items-baseline space-x-1 select-none">
        <span
          id="hours"
          class="text-[clamp(2.75rem,9vw,6rem)] leading-none font-extrabold tracking-tight text-text-header"
          >12</span
        >
        <span
          class="text-text-secondary/55 text-[clamp(2.75rem,9vw,6rem)] leading-none font-extrabold tracking-tight"
          >:</span
        >
        <span
          id="minutes"
          class="text-[clamp(2.75rem,9vw,6rem)] leading-none font-extrabold tracking-tight text-text-header"
          >59</span
        >
        <span
          class="text-text-secondary/55 text-[clamp(2.75rem,9vw,6rem)] leading-none font-extrabold tracking-tight"
          >:</span
        >
        <span
          id="seconds"
          class="text-text-secondary/75 text-[clamp(2.75rem,9vw,6rem)] leading-none font-extrabold tracking-tight"
          >48</span
        >
        <span
          id="ampm"
          class="text-text-secondary/65 mt-1.5 ml-2 self-start text-[clamp(0.75rem,2.2vw,1.1rem)] font-semibold"
          >AM</span
        >
      </div>

      <div class="max-w-lg px-6 text-center">
        <span class="text-text-secondary/90 text-base font-normal">
          {randomQuote}
        </span>
      </div>
    </div>

    <Shortcuts />

    <div
      class="bg-panel/88 border-border-default/70 fixed right-5 bottom-5 z-50 flex items-center gap-2.5 rounded-lg border px-3 py-2 backdrop-blur-md"
    >
      <span class="text-text-secondary/75 text-xs font-medium">v{VERSION}</span>
      <span class="bg-border-default/70 h-3 w-px"></span>
      <a
        href="https://github.com/Lunar-Proxy/lunar-v2"
        target="_blank"
        class="text-text-secondary/75 hover:text-text-header text-xs font-medium transition-colors"
      >
        GitHub
      </a>
      <span class="bg-border-default/70 h-3 w-px"></span>
      <a
        href="https://discord.gg/fuPtWjYuf8"
        target="_blank"
        class="text-text-secondary/75 hover:text-text-header text-xs font-medium transition-colors"
      >
        Discord
      </a>
    </div>
    <div
      class="bg-panel/88 border-border-default/70 fixed bottom-5 left-5 z-50 flex items-center gap-3 rounded-lg border px-3 py-2 backdrop-blur-md"
    >
      <span id="sl" class="text-text-secondary/75 text-xs font-medium tabular-nums">...</span>
      <div class="bg-border-default/70 h-3 w-px"></div>
      <button
        id="refresh"
        class="text-text-secondary/75 hover:text-text-header transition-all duration-300 hover:rotate-180 focus:outline-none"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-3.5 w-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-3-6.708M21 3v6h-6"
          ></path>
        </svg>
      </button>
    </div>

    <script src="@scripts/new"></script>
  </body>
</html>
