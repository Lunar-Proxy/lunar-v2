---
import '@/main.css';
import ImportLucide from '../layouts/lucide.astro';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

interface Game {
  name: string;
  desc: string;
  url: string;
  icon: string;
}

const { list = [] }: { list?: Game[] } = Astro.props;
const playsFile = join(process.cwd(), 'plays.json');
let plays: Record<string, number> = {};
try {
  if (existsSync(playsFile)) {
    const parsed = JSON.parse(readFileSync(playsFile, 'utf-8'));
    if (typeof parsed === 'object' && !Array.isArray(parsed)) plays = parsed;
  }
} catch {}

const popular = [...list]
  .map(g => ({ ...g, count: plays[g.name] || 0 }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 6);

const hasRealData = popular.some(g => g.count > 0);
const finalPopular = hasRealData ? popular : [...list].sort(() => Math.random() - 0.5).slice(0, 6);
const popularNames = new Set(finalPopular.map(g => g.name));
const sorted = [...list]
  .filter(g => !popularNames.has(g.name))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<html lang="en">
  <body class="bg-background font-linux text-text-header min-h-screen">
    <div class="mx-auto max-w-7xl space-y-8 p-5">
      <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold tracking-tight">Lunar Games</h1>
        <div class="bg-panel/75 flex gap-0.5 rounded-md border border-border-default/75 p-0.5">
          <button
            data-view="grid"
            class="bg-panel-hover/75 text-text-header flex h-7 w-7 items-center justify-center rounded transition-all duration-150"
          >
            <i data-lucide="grid-3x3" class="h-3.5 w-3.5"></i>
          </button>
          <button
            data-view="compact"
            class="text-text-secondary/75 flex h-7 w-7 items-center justify-center rounded transition-all duration-150"
          >
            <i data-lucide="layout-grid" class="h-3.5 w-3.5"></i>
          </button>
          <button
            data-view="list"
            class="text-text-secondary/75 flex h-7 w-7 items-center justify-center rounded transition-all duration-150"
          >
            <i data-lucide="list" class="h-3.5 w-3.5"></i>
          </button>
        </div>
      </div>

      {
        finalPopular.length > 0 && (
          <div>
            <div class="mb-3 flex items-center gap-2">
              <i data-lucide="flame" class="h-4 w-4 text-accent" />
              <h2 class="text-text-muted text-sm font-semibold tracking-widest">Popular</h2>
            </div>
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
              {finalPopular.map(g => (
                <div
                  data-href={g.url}
                  data-name={g.name}
                  data-bg={g.icon}
                  class="card card-loading group relative flex h-28 cursor-pointer flex-col justify-end overflow-hidden rounded-xl border border-border-default/70 transition-colors duration-150 hover:border-border-default"
                >
                  <div class="card-bg absolute inset-0 bg-cover bg-center opacity-66 transition-opacity duration-150 group-hover:opacity-78" />
                  <div class="absolute inset-0 bg-linear-to-t from-black/85 via-black/30 to-transparent" />
                  <div class="relative z-10 p-2.5">
                    <h2 class="text-text-header truncate text-xs font-semibold drop-shadow">{g.name}</h2>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )
      }

      <div class="flex flex-wrap items-center gap-2">
        <div class="relative max-w-md min-w-60 flex-1">
          <i
            data-lucide="search"
            class="text-text-secondary/70 pointer-events-none absolute top-1/2 left-2.5 z-10 h-3.5 w-3.5 -translate-y-1/2"
          ></i>
          <input
            type="text"
            data-input
            placeholder="Search games..."
            class="bg-panel/72 text-text-header placeholder:text-text-secondary/65 h-9 w-full rounded-md border border-border-default/75 pr-3 pl-9 text-sm transition-colors focus:border-border-default focus:outline-none"
          />
        </div>
        <button
          data-random
          class="bg-panel/72 text-text-secondary/80 hover:text-text-header flex h-9 items-center gap-2 rounded-md border border-border-default/75 px-3 text-sm transition-all duration-150 hover:border-border-default"
        >
          <i data-lucide="shuffle" class="h-3.5 w-3.5"></i>
          Random
        </button>
        <button
          data-sort
          class="bg-panel/72 text-text-secondary/80 hover:text-text-header flex h-9 items-center gap-2 rounded-md border border-border-default/75 px-3 text-sm transition-all duration-150 hover:border-border-default"
        >
          <i data-lucide="arrow-up-down" class="h-3.5 w-3.5"></i>
          <span>A-Z</span>
        </button>
      </div>

      <div>
        <div class="mb-3 flex items-center gap-2">
          <i data-lucide="grid-2x2" class="text-text-secondary/70 h-4 w-4"></i>
          <h2 class="text-text-muted text-sm font-semibold tracking-widest">All Games</h2>
        </div>
        <div
          data-container
          class="grid grid-cols-1 gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
        >
          {
            sorted.map(g => (
              <div
                data-href={g.url}
                data-name={g.name}
                data-bg={g.icon}
                class="card card-loading group relative flex h-40 cursor-pointer flex-col justify-end overflow-hidden rounded-xl border border-border-default/70 transition-colors duration-150 hover:border-border-default"
              >
                <div class="card-bg absolute inset-0 bg-cover bg-center opacity-66 transition-opacity duration-150 group-hover:opacity-78" />
                <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent" />
                <div class="relative z-10 p-3.5">
                  <h2 class="text-text-header mb-1 text-sm font-semibold drop-shadow">{g.name}</h2>
                  <p class="line-clamp-2 text-text-secondary/85 text-xs drop-shadow">{g.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div data-empty class="hidden flex-col items-center justify-center py-16 text-center">
        <div class="bg-panel/70 border-border-default/75 rounded-xl border p-10">
          <i data-lucide="inbox" class="text-text-secondary/45 mx-auto mb-3 h-10 w-10"></i>
          <h3 class="text-text-header/85 mb-1 text-base font-semibold">Nothing found</h3>
          <p class="text-text-secondary/80 text-sm">Try a different search term</p>
        </div>
      </div>
    </div>

    <ImportLucide />
    <script src="../utils/assets"></script>
  </body>
</html>
